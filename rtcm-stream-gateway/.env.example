# Capture
DEVICE=any
LISTEN_PORT=12101
SNAPLEN=262144
BUFFER_MB=64

# Caster B output
CASTER_HOST=rtktk.online
CASTER_PORT=1509
CASTER_PASS=123456
MOUNT_PREFIX=STN

# Source mapping lifecycle
SOURCE_IDLE_SEC=90
STATION_IDLE_SEC=600

# Web server
WEB_PORT=8080
METRICS_PORT=6060

# Worker pool
WORKER_MIN=4
WORKER_MAX=16
WORKER_QUEUE_SIZE=4096
AUTO_SCALE=true

# Config persistence
CONFIG_FILE=/app/configs/gateway.json
